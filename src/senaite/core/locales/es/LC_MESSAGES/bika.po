msgstr "El rango del resultado difiere de la especificación: {}"

# Si en algún punto se usa plantilla con mapping TAL (${spec}), añadimos esta variante:
#: bika/lims/browser/analyses/view.py
msgid "Result range is different from Specification: ${spec}"
msgstr "El rango del resultado difiere de la especificación: ${spec}"

