msgid "Unique code of the external laboratory. This code is used to ensure your laboratory and the external laboratory know each other on data transfer"
msgstr "Código único del laboratorio externo. Este código se utiliza para garantizar que su laboratorio y el externo se conozcan al transferir datos."

msgid "Reference Laboratory"
msgstr "Laboratorio de referencia"

msgid "Whether this external laboratory is capable of analysis or testing on samples sent from the current laboratory. When checked, this external laboratory will be displayed for selection when dispatching a sample"
msgstr "Si este laboratorio externo puede realizar análisis o pruebas en las muestras enviadas desde el laboratorio actual. Al marcar esta casilla, este laboratorio externo se mostrará para su selección al enviar una muestra."

msgid "Referring Laboratory"
msgstr "Laboratorio remitente"

msgid "Whether this external laboratory can send samples to your laboratory for additional analysis or testing. When checked, your SENAITE instance will accept samples for testing sent from this external laboratory"
msgstr "Si este laboratorio externo puede enviar muestras a su laboratorio para análisis o pruebas adicionales. Al marcar esta casilla, su instancia de SENAITE aceptará muestras para análisis enviadas desde este laboratorio externo."

msgid "Default client"
msgstr "Cliente predeterminado"

msgid "The default client for inbound sample shipments received from this external laboratory"
msgstr "El cliente predeterminado para los envíos de muestras entrantes recibidos de este laboratorio externo"

msgid "Default contact"
msgstr "Contacto predeterminado"

msgid "The default contact for inbound sample shipments received from this external laboratory"
msgstr "El contacto predeterminado para los envíos de muestras entrantes recibidos de este laboratorio externo"

msgid "Referral Settings"
msgstr "Configuración de referencias"

msgid "description_referral_create_reference_analyses"
msgstr "Si está habilitado, se crearán análisis de referencia para las muestras derivadas."

msgid "description_referral_notify_hidden_analyses"
msgstr "Si está seleccionado, los resultados de análisis ocultos se enviarán al laboratorio remitente tras la verificación de la muestra. Si no, los resultados marcados como ocultos no se compartirán."

msgid "description_referral_notify_retested_analyses"
msgstr "Si está seleccionado, los resultados de análisis repetidos se enviarán al laboratorio remitente tras la verificación de la muestra. Si no, solo se compartirán los resultados del reensayo."

msgid "description_referral_notify_unrequested_analyses"
msgstr "Si está seleccionado, los resultados de análisis no solicitados se enviarán al laboratorio remitente tras la verificación de la muestra. Si no, solo se compartirán los resultados de los análisis solicitados inicialmente."

msgid "description_referral_outbound_samples_order"
msgstr "Estrategia predeterminada de ordenamiento al añadir muestras a un envío saliente."

msgid "label_referral_code"
msgstr "Código"

msgid "label_referral_create_reference_analyses"
msgstr "Crear análisis de referencia"

msgid "label_referral_manual_inbound_permitted"
msgstr "Permitir creación manual de envíos entrantes"

msgid "label_referral_notify_hidden_analyses"
msgstr "Notificar sobre análisis ocultos"

msgid "label_referral_notify_retested_analyses"
msgstr "Notificar sobre análisis reensayados"

msgid "label_referral_notify_unrequested_analyses"
msgstr "Notificar sobre análisis no solicitados"

msgid "label_referral_outbound_samples_order"
msgstr "Orden predeterminado para muestras en envíos salientes"

msgid "Unique code of current instance's laboratory. This unique code is used by reference laboratories to identify this laboratory as a valid sample referrer."
msgstr "Código único del laboratorio de la instancia actual. Este código único lo utilizan los laboratorios de referencia para identificarlo como remitente válido de muestras."

msgid "Whether the manual creation of inbound sample shipments is permitted. If not enabled, the creation of inbound shipments will only be possible via POST requests by referral laboratories"
msgstr "Si se permite la creación manual de envíos de muestras entrantes. Si no está habilitada, la creación de envíos entrantes solo será posible mediante solicitudes POST de los laboratorios remitentes."

msgid "Show barcode labels preview on shipment reception"
msgstr "Mostrar vista previa de las etiquetas de código de barras al recibir el envío"

msgid "Whether the system must redirect the user to the barcode stickers preview when receiving samples from an incoming shipment"
msgstr "Si el sistema debe redirigir al usuario a la vista previa de las etiquetas de código de barras al recibir muestras de un envío entrante"

msgid "Maximum number of inbound samples to receive in a single task"
msgstr "Número máximo de muestras entrantes a recibir en una sola tarea"

msgid "If the number of inbound samples to receive is above this value, the queue will split the job in as many tasks as required. If the value is 0 or senaite queue is not installed, the system won't process the inbound samples asynchronously and all them will be held in a single request"
msgstr "Si el número de muestras entrantes a recibir supera este valor, la cola dividirá el trabajo en tantas tareas como sea necesario. Si el valor es 0 o no está instalado senaite.queue, el sistema no procesará las muestras entrantes de forma asíncrona y todas se gestionarán en una sola solicitud."

