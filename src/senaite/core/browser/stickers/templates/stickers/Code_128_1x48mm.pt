<tal:sticker define="portal_state context/@@plone_portal_state;
                     portal_url portal_state/portal_url;
                     item python:view.current_item;
                     sample_id item/getId;
                     sample_type item/getSampleTypeTitle;
                     date_sampled python:view.ulocalized_time(item.getDateSampled());
                     hazardous item/getHazardous;

                     patient python:item.getPatient();
                     patient_name python: getattr(item, 'getPatientFullName', lambda: '')() or (patient and getattr(patient, 'getFullname', lambda: '')()) or '';
                     patient_age  python: patient and getattr(patient, 'getCurrentAgeAsText', lambda: '')() or '';
                     patient_sex  python: getattr(item, 'getSex', lambda: '')() or (patient and getattr(patient, 'getSex', lambda: '')()) or '' ">

  <!-- Barcode -->
  <div class="barcode"
       tal:attributes="data-id sample_id;"
       data-code="code128"
       data-barHeight="12"
       data-addQuietZone="true"
       data-showHRI="false">
  </div>

  <!-- Some additional info about the sample -->
  <div class="sample-info">
    <table cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td rowspan="2" tal:condition="hazardous | nothing">
          <img tal:attributes="src string:${portal_url}/senaite_theme/icon/hazardous"/>
        </td>
        <td colspan="2">
          <strong tal:content="sample_id">Sample ID</strong>
        </td>
      </tr>
      <tr>
        <td>
          <div tal:content="date_sampled">Date Sampled</div>
          <div tal:content="sample_type">Sample Type</div>

          <!-- ADDED: Patient info (shown only if available) -->
          <div tal:condition="patient_name"
               tal:content="python:'Pac.: ' + patient_name">Pac.: Nombre</div>
          <div tal:condition="patient_age"
               tal:content="python:'Edad: ' + patient_age">Edad</div>
          <div tal:condition="patient_sex"
               tal:content="python:'Sexo: ' + patient_sex">Sexo</div>
          <!-- /ADDED -->
        </td>
      </tr>
    </table>
  </div>
</tal:sticker>
