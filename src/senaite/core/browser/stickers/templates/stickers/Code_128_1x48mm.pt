<tal:sticker define="portal_state context/@@plone_portal_state;
                     portal_url portal_state/portal_url;
                     item python:view.current_item;
                     sample_id item/getId;
                     sample_type item/getSampleTypeTitle;
                     date_sampled python:view.ulocalized_time(item.getDateSampled(), long_format=False);
                     hazardous item/getHazardous;
                     patient python: hasattr(item, 'getPatient') and item.getPatient() or None;">

  <!-- Compactar visualmente SOLO esta plantilla -->
  <style type="text/css">
    /* Todo dentro del alcance de esta etiqueta */
    .sticker .sample-info table { border-collapse: collapse; }
    .sticker .sample-info td { padding: 0; vertical-align: top; }
    .sticker .sample-info { font-size: 8px; line-height: 1.05; }
    .sticker .sample-info .patient-line,
    .sticker .sample-info .id-line,
    .sticker .sample-info .date-type-line {
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      max-width: 100%;
    }
    .sticker .sample-info .hazardous img { width: 10px; height: 10px; }
  </style>

  <!-- Barcode (altura levemente menor para ganar 1 línea) -->
  <div class="barcode"
       tal:attributes="data-id sample_id;"
       data-code="code128"
       data-barHeight="10"
       data-addQuietZone="true"
       data-showHRI="false">
  </div>

  <!-- Info -->
  <div class="sample-info">
    <table cellpadding="0" cellspacing="0" border="0">
      <tr>
        <!-- ahora hay 3 filas: ID, PACIENTE, FECHA/TIPO -->
        <td class="hazardous" rowspan="3" tal:condition="hazardous | nothing">
          <img tal:attributes="src string:${portal_url}/senaite_theme/icon/hazardous"/>
        </td>
        <td colspan="2" class="id-line">
          <strong tal:content="sample_id">Sample ID</strong>
        </td>
      </tr>

      <!-- Paciente (solo nombre, con fallbacks) -->
      <tr tal:condition="python: patient or hasattr(item, 'getPatientFullName')">
        <td colspan="2" class="patient-line">
          <span tal:condition="python: hasattr(item, 'getPatientFullName')"
                tal:content="python: item.getPatientFullName()">Nombre Paciente</span>
          <span tal:condition="python: not hasattr(item, 'getPatientFullName') and patient and hasattr(patient, 'getFullname')"
                tal:content="python: patient.getFullname()">Nombre Paciente</span>
          <span tal:condition="python: not hasattr(item, 'getPatientFullName') and patient and not hasattr(patient, 'getFullname') and hasattr(patient, 'Title')"
                tal:content="python: patient.Title()">Nombre Paciente</span>
        </td>
      </tr>

      <tr>
        <td colspan="2" class="date-type-line">
          <span tal:content="date_sampled">Date Sampled</span>
          &nbsp;•&nbsp;
          <span tal:content="sample_type">Sample Type</span>
        </td>
      </tr>
    </table>
  </div>
</tal:sticker>
