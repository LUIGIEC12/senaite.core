<tal:sticker define="portal_state context/@@plone_portal_state;
                     portal_url portal_state/portal_url;
                     item python:view.current_item;
                     sample_id item/getId;
                     sample_type item/getSampleTypeTitle;
                     date_sampled python:view.ulocalized_time(item.getDateSampled(), long_format=False);
                     hazardous item/getHazardous;
                     patient python: hasattr(item, 'getPatient') and item.getPatient() or None;">

  <!-- Estilos locales (centrado fuerte para vista e impresión) -->
  <style type="text/css">
    /* Asegurar que ningún estilo externo afecte medidas/alineación */
    .sticker, .sticker * { box-sizing: border-box; }

    /* Barcode siempre centrado */
    .sticker .barcode {
      display: block;
      width: 100%;
      margin: 0 auto;
      padding: 1mm 0 !important;
      text-align: center !important;
    }

    /* Contenedor de info como columna centrada con flexbox */
    .sticker .sample-info {
      display: flex;
      flex-direction: column;
      align-items: center;   /* centra horizontal */
      justify-content: flex-start;
      gap: 0;                /* sin separación adicional */
      width: 100%;
      margin: 0 auto;
      font-size: 8px;
      line-height: 1.05;
      text-align: center !important;   /* refuerzo */
    }

    /* Cada línea bloque centrado y con recorte de overflow */
    .sticker .sample-info .line {
      display: inline-flex;            /* se centra por el contenedor padre */
      align-items: center;             /* alinear icono + texto verticalmente */
      justify-content: center;
      max-width: 100%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      text-align: center !important;
    }

    .sticker .sample-info .id-line { font-weight: 700; }
    .sticker .sample-info .sex-age-line { font-size: 7.5px; } /* un pelín más compacta */

    .sticker .sample-info .hazardous-icon {
      width: 10px; height: 10px;
      margin-right: 2px;
      flex: 0 0 auto;
    }

    /* En caso de que existan estilos viejos con tablas, nos blindamos */
    .sticker .sample-info table,
    .sticker .sample-info tr,
    .sticker .sample-info td {
      all: initial;
      display: none !important; /* no usamos tablas aquí */
    }

    @media print {
      .sticker,
      .sticker .barcode,
      .sticker .sample-info,
      .sticker .sample-info .line {
        text-align: center !important;
        margin: 0 auto !important;
      }
    }
  </style>

  <!-- Código de barras -->
  <div class="barcode"
       tal:attributes="data-id sample_id;"
       data-code="code128"
       data-barHeight="10"
       data-addQuietZone="true"
       data-showHRI="false">
  </div>

  <!-- Info (sin tablas, 1 columna centrada) -->
  <div class="sample-info">
    <!-- Línea 1: (opcional) ícono hazardous + Sample ID -->
    <div class="line id-line">
      <tal:haz condition="hazardous | nothing">
        <img class="hazardous-icon"
             tal:attributes="src string:${portal_url}/senaite_theme/icon/hazardous"/>
      </tal:haz>
      <span tal:content="sample_id">Sample ID</span>
    </div>

    <!-- Línea 2: Paciente (solo nombre, con fallbacks) -->
    <tal:patientline condition="python: patient or hasattr(item, 'getPatientFullName')">
      <div class="line patient-line">
        <span tal:condition="python: hasattr(item, 'getPatientFullName')"
              tal:content="python: item.getPatientFullName()">Nombre Paciente</span>
        <span tal:condition="python: not hasattr(item, 'getPatientFullName') and patient and hasattr(patient, 'getFullname')"
              tal:content="python: patient.getFullname()">Nombre Paciente</span>
        <span tal:condition="python: not hasattr(item, 'getPatientFullName') and patient and not hasattr(patient, 'getFullname') and hasattr(patient, 'Title')"
              tal:content="python: patient.Title()">Nombre Paciente</span>
      </div>
    </tal:patientline>

    <!-- Línea 2.5 NUEVA: Sexo • Edad (se muestra solo si hay datos) -->
    <tal:sexageline condition="python:
          (hasattr(item, 'getSex') and item.getSex())
          or (patient and hasattr(patient, 'getSex') and patient.getSex())
          or (patient and (hasattr(patient, 'getCurrentAgeAsText') or hasattr(patient, 'getAgeAsText')))">
      <div class="line sex-age-line">
        <!-- Sexo (AR primero; si no, Patient) -->
        <span tal:condition="python: hasattr(item, 'getSex') and item.getSex()"
              tal:content="python: item.getSex()">Sexo</span>
        <span tal:condition="python: not (hasattr(item, 'getSex') and item.getSex()) and patient and hasattr(patient, 'getSex') and patient.getSex()"
              tal:content="python: patient.getSex()">Sexo</span>

        <!-- Separador "•" solo si hay sexo Y edad -->
        <span tal:condition="python:
              ((hasattr(item, 'getSex') and item.getSex()) or (patient and hasattr(patient, 'getSex') and patient.getSex()))
              and patient and (hasattr(patient, 'getCurrentAgeAsText') or hasattr(patient, 'getAgeAsText'))">
          &nbsp;•&nbsp;
        </span>

        <!-- Edad (preferir getCurrentAgeAsText) -->
        <span tal:condition="python: patient and hasattr(patient, 'getCurrentAgeAsText')"
              tal:content="python: patient.getCurrentAgeAsText()">Edad</span>
        <span tal:condition="python: patient and not hasattr(patient, 'getCurrentAgeAsText') and hasattr(patient, 'getAgeAsText')"
              tal:content="python: patient.getAgeAsText()">Edad</span>
      </div>
    </tal:sexageline>

    <!-- Línea 3: Fecha • Tipo de muestra -->
    <div class="line date-type-line">
      <span tal:content="date_sampled">Date Sampled</span>
      &nbsp;•&nbsp;
      <span tal:content="sample_type">Sample Type</span>
    </div>
  </div>
</tal:sticker>
