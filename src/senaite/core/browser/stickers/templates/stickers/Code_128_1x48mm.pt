<tal:sticker define="portal_state context/@@plone_portal_state;
                     portal_url portal_state/portal_url;
                     item python:view.current_item;
                     sample_id item/getId;
                     sample_type item/getSampleTypeTitle;
                     date_sampled python:view.ulocalized_time(item.getDateSampled(), long_format=False);
                     hazardous item/getHazardous;
                     patient python: hasattr(item, 'getPatient') and item.getPatient() or None;">

  <!-- Estilos locales (centrado fuerte para vista e impresión) -->
  <style type="text/css">
    .sticker, .sticker * { box-sizing: border-box; }
    .sticker .barcode {
      display: block; width: 100%; margin: 0 auto;
      padding: 1mm 0 !important; text-align: center !important;
    }
    .sticker .sample-info {
      display: flex; flex-direction: column;
      align-items: center; justify-content: flex-start;
      gap: 0; width: 100%; margin: 0 auto;
      font-size: 8px; line-height: 1.05; text-align: center !important;
    }
    .sticker .sample-info .line {
      display: inline-flex; align-items: center; justify-content: center;
      max-width: 100%; white-space: nowrap; overflow: hidden;
      text-overflow: ellipsis; text-align: center !important;
    }
    .sticker .sample-info .id-line { font-weight: 700; }
    .sticker .sample-info .sex-age-line { font-size: 7.5px; }
    .sticker .sample-info .hazardous-icon { width: 10px; height: 10px; margin-right: 2px; flex: 0 0 auto; }
    .sticker .sample-info table, .sticker .sample-info tr, .sticker .sample-info td { all: initial; display: none !important; }
    @media print {
      .sticker, .sticker .barcode, .sticker .sample-info, .sticker .sample-info .line {
        text-align: center !important; margin: 0 auto !important;
      }
    }
  </style>

  <!-- Código de barras -->
  <div class="barcode"
       tal:attributes="data-id sample_id;"
       data-code="code128"
       data-barHeight="10"
       data-addQuietZone="true"
       data-showHRI="false">
  </div>

  <!-- Info (sin tablas, 1 columna centrada) -->
  <div class="sample-info">
    <!-- Línea 1: (opcional) ícono hazardous + Sample ID -->
    <div class="line id-line">
      <tal:haz condition="hazardous | nothing">
        <img class="hazardous-icon"
             tal:attributes="src string:${portal_url}/senaite_theme/icon/hazardous"/>
      </tal:haz>
      <span tal:content="sample_id">Sample ID</span>
    </div>

    <!-- Línea 2: Paciente (solo nombre, con fallbacks) -->
    <tal:patientline condition="python: patient or hasattr(item, 'getPatientFullName')">
      <div class="line patient-line">
        <span tal:condition="python: hasattr(item, 'getPatientFullName')"
              tal:content="python: item.getPatientFullName()">Nombre Paciente</span>
        <span tal:condition="python: not hasattr(item, 'getPatientFullName') and patient and hasattr(patient, 'getFullname')"
              tal:content="python: patient.getFullname()">Nombre Paciente</span>
        <span tal:condition="python: not hasattr(item, 'getPatientFullName') and patient and not hasattr(patient, 'getFullname') and hasattr(patient, 'Title')"
              tal:content="python: patient.Title()">Nombre Paciente</span>
      </div>
    </tal:patientline>

    <!-- Línea 2.5: Sexo • Edad (sexo ya te funcionaba; añadimos edad robusta) -->
    <tal:sexage define="
        sex_raw python: (hasattr(item,'getSex') and item.getSex()) or (patient and hasattr(patient,'getSex') and patient.getSex()) or (patient and hasattr(patient,'getGender') and patient.getGender()) or '';
        sex_lc  python: sex_raw and sex_raw.strip().lower() or '';
        sex_txt python: (sex_lc and ((sex_lc.startswith('f') or sex_lc.startswith('w')) and 'femenino' or ((sex_lc.startswith('m') or sex_lc.startswith('h')) and 'masculino' or sex_lc))) or '';

        age_raw python: patient and ((hasattr(patient,'getCurrentAgeAsText') and patient.getCurrentAgeAsText()) or (hasattr(patient,'getAgeAsText') and patient.getAgeAsText())) or '';

        now_dt  python: modules['DateTime'].DateTime();
        ref_dt  python: (hasattr(item,'getDateSampled') and item.getDateSampled()) or now_dt;

        dob_raw python: patient and ((hasattr(patient,'getDateOfBirth') and patient.getDateOfBirth()) or (hasattr(patient,'getBirthDate') and patient.getBirthDate()) or (hasattr(patient,'getBirthdate') and patient.getBirthdate())) or None;
        dob_dt  python: dob_raw and modules['DateTime'].DateTime(dob_raw) or None;

        delta_d python: (dob_dt and (ref_dt - dob_dt) and float(ref_dt - dob_dt)) or 0.0;
        years_i python: int(delta_d/365.25);
        months_i python: int(delta_d/30.4375);
        days_i python: int(round(delta_d));

        age_calc python: dob_dt and (years_i >= 1 and ('%d años' % years_i) or (months_i >= 1 and ('%d meses' % months_i) or ('%d días' % days_i))) or '';

        age_txt python: (age_raw and age_raw.replace('years','años').replace('year','año').replace('yrs','años').replace('yr','año').replace('months','meses').replace('month','mes').replace('days','días').replace('day','día')) or age_calc;
      ">
      <div class="line sex-age-line" tal:condition="python: sex_txt or age_txt">
        <span tal:condition="python: sex_txt" tal:content="python: sex_txt">femenino</span>
        <span tal:condition="python: sex_txt and age_txt">&nbsp;•&nbsp;</span>
        <span tal:condition="python: age_txt" tal:content="python: age_txt">42 años</span>
      </div>
    </tal:sexage>

    <!-- Línea 3: Fecha • Tipo de muestra -->
    <div class="line date-type-line">
      <span tal:content="date_sampled">Date Sampled</span>
      &nbsp;•&nbsp;
      <span tal:content="sample_type">Sample Type</span>
    </div>
  </div>
</tal:sticker>
